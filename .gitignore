__pycache__/
*.pyc

# Local docker-compose overrides (e.g. host port mapping) — keep these
# out of the upstream repo. Drop a `docker-compose.override.yml` here
# to customize for your machine without affecting community users.
docker-compose.override.yml

# uv / virtualenv / build artifacts
.venv/
*.egg-info/
.uv-cache/

# Single-branch bare clone used as the source of file:///srv/reachability
# inside the docker-compose stack. Created by `uv run invoke demo.start`
# (or `demo.prepare-repo-source`); should never be committed.
.demo-bare/
